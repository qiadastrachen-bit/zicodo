{
  "name": "digital-life-backend",
  "version": "1.0.0",
  "description": "数字生命 - 后端服务 (Express + SQLite + Sequelize)",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "init-db": "node src/db/init.js",
    "test": "jest --runInBand",
    "migrate": "node src/db/migrate.js up",
    "migrate:up": "node src/db/migrate.js up",
    "migrate:down": "node src/db/migrate.js down",
    "migrate:pending": "node src/db/migrate.js pending",
    "migrate:executed": "node src/db/migrate.js executed",
    "smoke": "node src/_api-smoke-test.js",
    "migrate:reset-log": "node -e \"const fs=require('fs');const p='data/migrations-log.json';if(fs.existsSync(p))fs.unlinkSync(p);console.log('migrations-log 已删除');\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "sequelize": "^6.37.3",
    "sqlite3": "^5.1.7",
    "umzug": "^3.8.3",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
