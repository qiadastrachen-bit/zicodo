# 字灵后端环境变量配置
# 复制此文件为 .env 并填写真实值

# DeepSeek AI API Key（申请地址：https://platform.deepseek.com/，复制为 .env 后填写）
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY_HERE

# AI 提供商（固定 deepseek）
AI_PROVIDER=deepseek
AI_MODEL=deepseek-chat

# JWT 密钥（生产环境请更换）
JWT_SECRET=ziling-secret-key-2026

# 运行环境
NODE_ENV=production

# 端口
PORT=3000

# SQLite 数据库路径（相对 backend 目录）
DB_PATH=./data/zicodo.db

# CORS（开发环境前端地址）
CORS_ORIGIN=http://localhost:5173
