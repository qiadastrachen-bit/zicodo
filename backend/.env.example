# ============================================
# zicodo 后端环境变量模板
# 使用方法：复制本文件为 .env 并按需修改
# 注意：.env 文件不要提交到 Git（已添加到 .gitignore）
# ============================================

# ─── 服务器配置 ──────────────────────────────
PORT=3000
HOST=0.0.0.0

# ─── 运行环境 ────────────────────────────────
# development: 开发环境，输出详细日志
# production:  生产环境，精简日志输出
NODE_ENV=production

# ─── 数据库配置 ─────────────────────────────
# SQLite 数据库文件路径（相对或绝对路径）
# 容器内默认路径：/app/data/digital_life.db
DB_PATH=/app/data/digital_life.db

# ─── 安全配置（生产环境务必修改！） ─────────
# 请修改为随机长字符串（建议至少 32 位）
SESSION_SECRET=please_change_this_to_a_long_random_string_xxxxxxxxxxx
JWT_SECRET=please_change_this_to_another_long_random_string_yyyyyyy

# ─── AI 对话配置（可选） ───────────────────
# DeepSeek API 配置：
#   - 未配置时系统自动进入 Mock 模式
#   - 配置后启用真实 AI 对话
DEEPSEEK_API_KEY=your_deepseek_api_key_here_or_leave_blank_for_mock
DEEPSEEK_API_URL=https://api.deepseek.com

# ─── CORS 配置 ─────────────────────────────
# 允许的前端来源：
#   - "*"                → 允许所有来源（开发用）
#   - "https://yoursite.com" → 指定具体域名（生产推荐）
CORS_ORIGIN=*

# ─── 日志级别 ─────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info
