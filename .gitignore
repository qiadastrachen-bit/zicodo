# ============================================
# .gitignore - zicodo 项目根目录
# 排除所有不应该提交到 Git 的文件
# ============================================

# ─── 依赖目录 ─────────────────────────────
node_modules/
**/node_modules/
bower_components/

# ─── 构建产物 ─────────────────────────────
dist/
build/
**/dist/
**/build/

# ─── 环境变量（敏感信息，绝不提交！） ───
.env
.env.local
.env.*.local
.env.development
.env.production
**/.env
!**/.env.example

# ─── 数据库和数据文件 ───────────────────
*.db
*.sqlite
*.sqlite3
data/
**/data/

# ─── 日志文件 ────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── 测试和覆盖率 ───────────────────────
coverage/
.nyc_output/

# ─── 编辑器和 IDE ───────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/*.code-snippets
.idea/
*.swp
*.swo

# ─── 操作系统 ───────────────────────────
.DS_Store
Thumbs.db

# ─── 临时文件 ───────────────────────────
*.tmp
*.bak
*.pid
.cache/
.temp/

# ─── WorkBuddy 内部文件 ─────────────────
.workbuddy/
